rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Venues: public read, no client write ──────────────────────────────────
    match /venues/{venueId} {
      allow read: if true;
      allow write: if false;   // written only by backend services

      // Zones: public read
      match /zones/{zoneId} {
        allow read: if true;
        allow write: if false;
      }

      // Amenities: public read
      match /amenities/{amenityId} {
        allow read: if true;
        allow write: if false;

        // Menu items: public read
        match /menuItems/{itemId} {
          allow read: if true;
          allow write: if false;
        }

        // Order queue: service-only (no client access)
        match /orderQueue/{orderId} {
          allow read, write: if false;
        }
      }

      // Alerts: authenticated read, no client write
      match /alerts/{alertId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    // ── Attendee profiles: own data only ──────────────────────────────────────
    match /attendees/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Virtual queues: authenticated read/write (join/leave) ─────────────────
    match /queues/{amenityId} {
      allow read: if request.auth != null;
      allow write: if false;   // mutations only via queue-service

      match /entries/{entryId} {
        allow read: if request.auth != null &&
                       (resource.data.attendeeUid == request.auth.uid || request.auth.uid != null);
        allow write: if false;
      }
    }

    // ── Staff positions: authenticated read, no client write ──────────────────
    match /staff/{staffId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Everything else: deny ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
